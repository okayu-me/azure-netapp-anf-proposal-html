  <title>Azure NetApp Files – FileからAIデータ基盤へ</title>
  <style>
    body {
      margin: 0;
      font-family: "Segoe UI", "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
      background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
      color: #ffffff;
      overflow-x: hidden;
    }
    section {
      min-height: 100vh;
      padding: 80px 10%;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    h1 {
      font-size: 3.2em;
      line-height: 1.2;
      margin-bottom: 20px;
    }
    h2 {
      font-size: 2.2em;
      margin-bottom: 16px;
    }
    p {
      font-size: 1.2em;
      line-height: 1.8;
      max-width: 900px;
    }
    .highlight {
      color: #4fd1ff;
      font-weight: 600;
    }
    .fadein {
      animation: fadeInUp 1.5s ease-out forwards;
      opacity: 0;
    }
    @keyframes fadeInUp {
      from { transform: translateY(40px); opacity: 0; }
      to   { transform: translateY(0);  opacity: 1; }
    }
    .visual {
      margin-top: 40px;
      padding: 30px;
      background: rgba(255,255,255,0.08);
      border-radius: 16px;
      backdrop-filter: blur(10px);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px;
      margin-top: 32px;
    }
    .card {
      padding: 24px;
      background: linear-gradient(160deg, rgba(255,255,255,0.15), rgba(255,255,255,0.03));
      border-radius: 12px;
      font-size: 1.05em;
